rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Secure user-scoped data (profiles, accounts, transactions, settings)
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Secure license keys collection
    match /keys/{keyId} {
      // Any authenticated user can read/lookup key details to verify it
      allow read: if request.auth != null;

      // Only authorized reseller admin emails can generate new keys client-side
      allow create: if request.auth != null && 
        request.auth.token.email == 'rockyashok7313@gmail.com';

      // Any authenticated user can activate (update) an unused key for their profile
      allow update: if request.auth != null &&
        resource.data.status == 'unused' &&
        request.resource.data.status == 'used' &&
        request.resource.data.usedBy == request.auth.uid &&
        request.resource.data.usedAt != null;

      // Deleting keys from the client is prohibited
      allow delete: if false;
    }
  }
}
