rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwnerByUid(userId) {
      return request.auth.uid == userId;
    }

    // Phone users: check if request.auth.token contains phone or if user's ID matches request.auth.uid
    function isPhonePath(userId) {
      return userId == 'p_' + request.auth.token.phone_number || userId == request.auth.uid;
    }

    // Email OTP users: check if request.auth.token.email matches sanitized email ID
    function isEmailOtpPath(userId) {
      return userId == 'e_' + request.auth.token.email || userId == request.auth.uid;
    }

    // User-scoped data: profiles, accounts, transactions, settings
    match /users/{userId}/{document=**} {
      allow read, write: if isSignedIn() &&
        (isOwnerByUid(userId) || isPhonePath(userId) || isEmailOtpPath(userId));
    }

    // License keys collection
    match /keys/{keyId} {
      allow read: if isSignedIn();

      // Only admin can create keys directly from client
      allow create: if isSignedIn() &&
        request.auth.token.email == 'rockyashok7313@gmail.com';

      // Any authenticated user can activate an unused key
      // usedBy may be a UID, p_<phone>, or e_<email> depending on auth method
      allow update: if isSignedIn() &&
        resource.data.status == 'unused' &&
        request.resource.data.status == 'used' &&
        request.resource.data.usedAt != null &&
        (request.resource.data.usedBy == request.auth.uid ||
         request.resource.data.usedBy.matches('p_.*') ||
         request.resource.data.usedBy.matches('e_.*'));

      allow delete: if false;
    }
  }
}
